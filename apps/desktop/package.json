{
  "name": "@latex-agent/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -b",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "start": "npm run build && electron dist/main/index.js"
  },
  "dependencies": {
    "@latex-agent/agent-host": "0.0.0",
    "@latex-agent/document-service": "0.0.0",
    "@latex-agent/history-service": "0.0.0",
    "@latex-agent/ipc-contracts": "0.0.0",
    "@latex-agent/latex-service": "^0.0.0",
    "@latex-agent/pdf-service": "^0.0.0",
    "@latex-agent/project-lifecycle-service": "0.0.0",
    "@latex-agent/project-service": "0.0.0",
    "@latex-agent/reference-service": "0.0.0",
    "@latex-agent/ui": "0.0.0",
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^1.17.0",
    "monaco-editor": "0.53.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
